# OpenAI API Configuration
# Copy this file to .env and fill in your actual credentials

# OpenAI API endpoint (or compatible endpoint like Azure OpenAI, local LLM server)
BASE_URL=https://api.openai.com/v1

# Your OpenAI API key
API_KEY=sk-your-api-key-here

# Optional: Model to use for embeddings (default: text-embedding-ada-002)
# EMBEDDING_MODEL=text-embedding-ada-002

# Optional: Model to use for text generation (if needed)
# GENERATION_MODEL=gpt-3.5-turbo
